<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDInventariosMovimientos' >       EXECUTE bop_InventariosMovimientos_ObtenerNextID #id_Empresa#, #id_Sucursal#, #id_Almacen# </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDInventariosMovimientos.NextID> <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarInventariosMovimientos' >      EXECUTE bop_InventariosMovimientos_ObtenerPorID #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento# </cfquery> <cfreturn LOCAL.RS_MostrarInventariosMovimientos></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>  <cfargument name='id_Empresa' type='numeric' required='no' default='-1'>   <cfargument name='id_Sucursal' type='numeric' required='no' default='-1'>  <cfargument name='id_Almacen' type='numeric' required='no' default='-1'>   <cfargument name='id_Movimiento' type='numeric' required='no' default='-1'>    <cfargument name='id_TipoMovimiento' type='numeric' required='no' default='-1'>    <cfargument name='fl_Movimiento' type='string' required='no' default=''>   <cfargument name='fh_Movimiento' type='string' required='no' default=''>   <cfargument name='fl_FacturaRemision' type='string' required='no' default=''>  <cfargument name='fh_FacturaRemision' type='string' required='no' default=''>  <cfargument name='im_TotalMN' type='numeric' required='no' default=''> <cfargument name='de_Entrego' type='string' required='no' default=''>  <cfargument name='id_UsuarioEntrego' type='numeric' required='no' default='-1'>    <cfargument name='de_Recibio' type='string' required='no' default=''>  <cfargument name='id_UsuarioRecibio' type='numeric' required='no' default='-1'>    <cfargument name='id_OrdenCompra' type='numeric' required='no' default='-1'>   <cfargument name='id_Requisicion' type='numeric' required='no' default='-1'>   <cfargument name='de_Comentarios' type='string' required='no' default=''>  <cfargument name='id_InventarioTraspaso' type='numeric' required='no' default='-1'>    <cfargument name='id_InventarioFisico' type='numeric' required='no' default='-1'>  <cfargument name='id_MovimientoDevolucion' type='numeric' required='no' default='-1'>  <cfargument name='id_UsuarioRegistroMovimiento' type='numeric' required='no' default='-1'> <cfargument name='fh_Registro' type='string' required='no' default=''> <cfargument name='id_OrigenMovimientoAjuste' type='numeric' required='no' default='-1'>    <cfargument name='id_Poliza' type='numeric' required='no' default='-1'>    <cfargument name='id_EstatusSurtidoTraspaso' type='numeric' required='no' default='-1'>    <cfset LOCAL.WhereDinamico=''> <cfif #id_Empresa# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Empresa = #id_Empresa#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Empresa = #id_Empresa#">        </cfif>    </cfif>    <cfif #id_Sucursal# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Sucursal = #id_Sucursal#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Sucursal = #id_Sucursal#">      </cfif>    </cfif>    <cfif #id_Almacen# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Almacen = #id_Almacen#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Almacen = #id_Almacen#">        </cfif>    </cfif>    <cfif #id_Movimiento# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Movimiento = #id_Movimiento#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Movimiento = #id_Movimiento#">      </cfif>    </cfif>    <cfif #id_TipoMovimiento# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_TipoMovimiento = #id_TipoMovimiento#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_TipoMovimiento = #id_TipoMovimiento#">      </cfif>    </cfif>    <cfif #fl_Movimiento# NEQ ''>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fl_Movimiento LIKE '#fl_Movimiento#%'">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fl_Movimiento LIKE '#fl_Movimiento#%'">        </cfif>    </cfif>    <cfif #fh_Movimiento# NEQ ''>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fh_Movimiento = '#fh_Movimiento#'">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fh_Movimiento = '#fh_Movimiento#'">        </cfif>    </cfif>    <cfif #fl_FacturaRemision# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fl_FacturaRemision LIKE '#fl_FacturaRemision#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fl_FacturaRemision LIKE '#fl_FacturaRemision#%'">      </cfif>    </cfif>    <cfif #fh_FacturaRemision# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fh_FacturaRemision = '#fh_FacturaRemision#'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fh_FacturaRemision = '#fh_FacturaRemision#'">      </cfif>    </cfif>    <cfif #im_TotalMN# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE im_TotalMN = #im_TotalMN#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND im_TotalMN = #im_TotalMN#">        </cfif>    </cfif>    <cfif #de_Entrego# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_Entrego LIKE '#de_Entrego#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_Entrego LIKE '#de_Entrego#%'">      </cfif>    </cfif>    <cfif #id_UsuarioEntrego# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_UsuarioEntrego = #id_UsuarioEntrego#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_UsuarioEntrego = #id_UsuarioEntrego#">      </cfif>    </cfif>    <cfif #de_Recibio# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_Recibio LIKE '#de_Recibio#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_Recibio LIKE '#de_Recibio#%'">      </cfif>    </cfif>    <cfif #id_UsuarioRecibio# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_UsuarioRecibio = #id_UsuarioRecibio#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_UsuarioRecibio = #id_UsuarioRecibio#">      </cfif>    </cfif>    <cfif #id_OrdenCompra# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_OrdenCompra = #id_OrdenCompra#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_OrdenCompra = #id_OrdenCompra#">        </cfif>    </cfif>    <cfif #id_Requisicion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Requisicion = #id_Requisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Requisicion = #id_Requisicion#">        </cfif>    </cfif>    <cfif #de_Comentarios# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_Comentarios LIKE '#de_Comentarios#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_Comentarios LIKE '#de_Comentarios#%'">      </cfif>    </cfif>    <cfif #id_InventarioTraspaso# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_InventarioTraspaso = #id_InventarioTraspaso#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_InventarioTraspaso = #id_InventarioTraspaso#">      </cfif>    </cfif>    <cfif #id_InventarioFisico# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_InventarioFisico = #id_InventarioFisico#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_InventarioFisico = #id_InventarioFisico#">      </cfif>    </cfif>    <cfif #id_MovimientoDevolucion# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_MovimientoDevolucion = #id_MovimientoDevolucion#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_MovimientoDevolucion = #id_MovimientoDevolucion#">      </cfif>    </cfif>    <cfif #id_UsuarioRegistroMovimiento# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_UsuarioRegistroMovimiento = #id_UsuarioRegistroMovimiento#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_UsuarioRegistroMovimiento = #id_UsuarioRegistroMovimiento#">        </cfif>    </cfif>    <cfif #fh_Registro# NEQ ''>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fh_Registro = '#fh_Registro#'">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fh_Registro = '#fh_Registro#'">        </cfif>    </cfif>    <cfif #id_OrigenMovimientoAjuste# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_OrigenMovimientoAjuste = #id_OrigenMovimientoAjuste#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_OrigenMovimientoAjuste = #id_OrigenMovimientoAjuste#">      </cfif>    </cfif>    <cfif #id_Poliza# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Poliza = #id_Poliza#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Poliza = #id_Poliza#">      </cfif>    </cfif>    <cfif #id_EstatusSurtidoTraspaso# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_EstatusSurtidoTraspaso = #id_EstatusSurtidoTraspaso#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_EstatusSurtidoTraspaso = #id_EstatusSurtidoTraspaso#">      </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoInventariosMovimientos' >      EXECUTE bop_InventariosMovimientos_ObtenerDinamico '#LOCAL.WhereDinamico#' </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoInventariosMovimientos></cffunction><cffunction name='getRSTodos' access='public' returntype='query'> <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosInventariosMovimientos' >     EXECUTE bop_InventariosMovimientos_ObtenerTodos    </cfquery> <cfreturn LOCAL.RS_MostrarTodosInventariosMovimientos></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>  <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfargument name='id_TipoMovimiento' type='numeric' required='yes'>    <cfargument name='fl_Movimiento' type='string' required='yes'> <cfargument name='fh_Movimiento' type='string' required='yes'> <cfargument name='fl_FacturaRemision' type='string' required='no'> <cfargument name='fh_FacturaRemision' type='string' required='no'> <cfargument name='im_TotalMN' type='numeric' required='no'>    <cfargument name='de_Entrego' type='string' required='no'> <cfargument name='id_UsuarioEntrego' type='numeric' required='no'> <cfargument name='de_Recibio' type='string' required='no'> <cfargument name='id_UsuarioRecibio' type='numeric' required='no'> <cfargument name='id_OrdenCompra' type='numeric' required='no'>    <cfargument name='id_Requisicion' type='numeric' required='no'>    <cfargument name='de_Comentarios' type='string' required='no'> <cfargument name='id_InventarioTraspaso' type='numeric' required='no'> <cfargument name='id_InventarioFisico' type='numeric' required='no'>   <cfargument name='id_MovimientoDevolucion' type='numeric' required='no'>   <cfargument name='id_UsuarioRegistroMovimiento' type='numeric' required='yes'> <cfargument name='fh_Registro' type='string' required='yes'>   <cfargument name='id_OrigenMovimientoAjuste' type='numeric' required='no'> <cfargument name='id_Poliza' type='numeric' required='no'> <cfargument name='id_EstatusSurtidoTraspaso' type='numeric' required='no'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_InventariosMovimientos_Agregar                 #id_Empresa#,              #id_Sucursal#,                 #id_Almacen#,              #id_Movimiento#,               #id_TipoMovimiento#,               '#fl_Movimiento#',                 '#fh_Movimiento#',                 <cfif Not IsDefined('arguments.fl_FacturaRemision')>NULL<cfelse>'#fl_FacturaRemision#'</cfif>,                 <cfif Not IsDefined('arguments.fh_FacturaRemision')  OR arguments.fh_FacturaRemision EQ ''>NULL<cfelse>'#fh_FacturaRemision#'</cfif>,              <cfif Not IsDefined('arguments.im_TotalMN')>NULL<cfelse>#im_TotalMN#</cfif>,               <cfif Not IsDefined('arguments.de_Entrego')>NULL<cfelse>'#de_Entrego#'</cfif>,                 <cfif Not IsDefined('arguments.id_UsuarioEntrego')>NULL<cfelse>#id_UsuarioEntrego#</cfif>,                 <cfif Not IsDefined('arguments.de_Recibio')>NULL<cfelse>'#de_Recibio#'</cfif>,                 <cfif Not IsDefined('arguments.id_UsuarioRecibio')>NULL<cfelse>#id_UsuarioRecibio#</cfif>,                 <cfif Not IsDefined('arguments.id_OrdenCompra')>NULL<cfelse>#id_OrdenCompra#</cfif>,               <cfif Not IsDefined('arguments.id_Requisicion')>NULL<cfelse>#id_Requisicion#</cfif>,               <cfif IsDefined('arguments.de_Comentarios') AND #arguments.de_Comentarios# NEQ ''>'#de_Comentarios#'<cfelse>NULL</cfif>,               <cfif Not IsDefined('arguments.id_InventarioTraspaso')>NULL<cfelse>#id_InventarioTraspaso#</cfif>,                 <cfif Not IsDefined('arguments.id_InventarioFisico')>NULL<cfelse>#id_InventarioFisico#</cfif>,                 <cfif Not IsDefined('arguments.id_MovimientoDevolucion')>NULL<cfelse>#id_MovimientoDevolucion#</cfif>,                 #id_UsuarioRegistroMovimiento#,                '#fh_Registro#',               <cfif Not IsDefined('arguments.id_OrigenMovimientoAjuste')>NULL<cfelse>#id_OrigenMovimientoAjuste#</cfif>,                 <cfif Not IsDefined('arguments.id_Poliza')>NULL<cfelse>#id_Poliza#</cfif>,                 <cfif Not IsDefined('arguments.id_EstatusSurtidoTraspaso')>NULL<cfelse>#id_EstatusSurtidoTraspaso#</cfif>  </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfargument name='id_TipoMovimiento' type='numeric' required='yes'>    <cfargument name='fl_Movimiento' type='string' required='yes'> <cfargument name='fh_Movimiento' type='string' required='yes'> <cfargument name='fl_FacturaRemision' type='string' required='no'> <cfargument name='fh_FacturaRemision' type='string' required='no'> <cfargument name='im_TotalMN' type='numeric' required='no'>    <cfargument name='de_Entrego' type='string' required='no'> <cfargument name='id_UsuarioEntrego' type='numeric' required='no'> <cfargument name='de_Recibio' type='string' required='no'> <cfargument name='id_UsuarioRecibio' type='numeric' required='no'> <cfargument name='id_OrdenCompra' type='numeric' required='no'>    <cfargument name='id_Requisicion' type='numeric' required='no'>    <cfargument name='de_Comentarios' type='string' required='no'> <cfargument name='id_InventarioTraspaso' type='numeric' required='no'> <cfargument name='id_InventarioFisico' type='numeric' required='no'>   <cfargument name='id_MovimientoDevolucion' type='numeric' required='no'>   <cfargument name='id_UsuarioRegistroMovimiento' type='numeric' required='yes'> <cfargument name='fh_Registro' type='string' required='yes'>   <cfargument name='id_OrigenMovimientoAjuste' type='numeric' required='no'> <cfargument name='id_Poliza' type='numeric' required='no'> <cfargument name='id_EstatusSurtidoTraspaso' type='numeric' required='no'> <cfquery datasource="#variables.cnx#" >        EXECUTE bop_InventariosMovimientos_Actualizar #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento#, #id_TipoMovimiento#, '#fl_Movimiento#', '#fh_Movimiento#', <cfif Not IsDefined('arguments.fl_FacturaRemision')>NULL<cfelse>'#fl_FacturaRemision#'</cfif>, <cfif Not IsDefined('arguments.fh_FacturaRemision')>NULL<cfelse>'#fh_FacturaRemision#'</cfif>, <cfif Not IsDefined('arguments.im_TotalMN')>NULL<cfelse>#im_TotalMN#</cfif>, <cfif Not IsDefined('arguments.de_Entrego')>NULL<cfelse>'#de_Entrego#'</cfif>, <cfif Not IsDefined('arguments.id_UsuarioEntrego')>NULL<cfelse>#id_UsuarioEntrego#</cfif>, <cfif Not IsDefined('arguments.de_Recibio')>NULL<cfelse>'#de_Recibio#'</cfif>, <cfif Not IsDefined('arguments.id_UsuarioRecibio')>NULL<cfelse>#id_UsuarioRecibio#</cfif>, <cfif Not IsDefined('arguments.id_OrdenCompra')>NULL<cfelse>#id_OrdenCompra#</cfif>, <cfif Not IsDefined('arguments.id_Requisicion')>NULL<cfelse>#id_Requisicion#</cfif>, <cfif Not IsDefined('arguments.de_Comentarios')>NULL<cfelse>'#de_Comentarios#'</cfif>, <cfif Not IsDefined('arguments.id_InventarioTraspaso')>NULL<cfelse>#id_InventarioTraspaso#</cfif>, <cfif Not IsDefined('arguments.id_InventarioFisico')>NULL<cfelse>#id_InventarioFisico#</cfif>, <cfif Not IsDefined('arguments.id_MovimientoDevolucion')>NULL<cfelse>#id_MovimientoDevolucion#</cfif>, #id_UsuarioRegistroMovimiento#, '#fh_Registro#', <cfif Not IsDefined('arguments.id_OrigenMovimientoAjuste')>NULL<cfelse>#id_OrigenMovimientoAjuste#</cfif>, <cfif Not IsDefined('arguments.id_Poliza')>NULL<cfelse>#id_Poliza#</cfif>, <cfif Not IsDefined('arguments.id_EstatusSurtidoTraspaso')>NULL<cfelse>#id_EstatusSurtidoTraspaso#</cfif> </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_InventariosMovimientos_Eliminar #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento# </cfquery> <cfreturn></cffunction><cffunction name='getColumnaPorID' access='public' returntype='string'>  <cfargument name='id_Empresa' type='string' required='yes'>    <cfargument name='id_Sucursal' type='string' required='yes'>   <cfargument name='id_Almacen' type='string' required='yes'>    <cfargument name='id_Movimiento' type='string' required='yes'> <cfargument name='nb_Campo' type='string' required='yes'>  <cfif  Not IsNumeric(id_Empresa) OR Not IsNumeric(id_Sucursal) OR Not IsNumeric(id_Almacen) OR Not IsNumeric(id_Movimiento)>       <cfset LOCAL.Columna_Retorno= ''>  <cfelse>       <cfquery datasource="#variables.cnx#" name='LOCAL.RS_Mostrar_InventariosMovimientos' >         EXECUTE bop_InventariosMovimientos_ObtenerPorID #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento#     </cfquery>     <cfset LOCAL.Columna_Retorno= Evaluate('LOCAL.RS_Mostrar_InventariosMovimientos.#nb_Campo#')>  </cfif>    <cfreturn LOCAL.Columna_Retorno></cffunction></cfcomponent>