<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDRequisicionesDetalle' >     EXECUTE bop_RequisicionesDetalle_ObtenerNextID #id_Empresa#, #id_Requisicion#  </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDRequisicionesDetalle.NextID>   <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_RequisicionDetalle' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarRequisicionesDetalle' >        EXECUTE bop_RequisicionesDetalle_ObtenerPorID #id_Empresa#, #id_Requisicion#, #id_RequisicionDetalle#  </cfquery> <cfreturn LOCAL.RS_MostrarRequisicionesDetalle></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>    <cfargument name='id_Empresa' type='numeric' required='no' default='-1'>   <cfargument name='id_Requisicion' type='numeric' required='no' default='-1'>   <cfargument name='id_RequisicionDetalle' type='numeric' required='no' default='-1'>    <cfargument name='id_Insumo' type='numeric' required='no' default='-1'>    <cfargument name='nu_Cantidad' type='numeric' required='no' default='-1'>  <cfargument name='im_PrecioUnitario' type='numeric' required='no' default='-1'>    <cfargument name='nu_CantidadSurtida' type='numeric' required='no' default='-1'>   <cfargument name='id_EstatusSurtido' type='numeric' required='no' default='-1'>    <cfargument name='id_SucursalCentroCosto' type='numeric' required='no' default='-1'>   <cfargument name='id_CentroCosto' type='numeric' required='no' default='-1'>   <cfargument name='id_Moneda' type='numeric' required='no' default='-1'>    <cfargument name='im_TipoCambio' type='numeric' required='no' default='-1'>    <cfargument name='id_grupoGasto' type='numeric' required='no' default='-1'>    <cfargument name='id_conceptoGasto' type='numeric' required='no' default='-1'> <cfset LOCAL.WhereDinamico=''> <cfif #id_Empresa# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Empresa = #id_Empresa#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Empresa = #id_Empresa#">        </cfif>    </cfif>    <cfif #id_Requisicion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Requisicion = #id_Requisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Requisicion = #id_Requisicion#">        </cfif>    </cfif>    <cfif #id_RequisicionDetalle# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_RequisicionDetalle = #id_RequisicionDetalle#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_RequisicionDetalle = #id_RequisicionDetalle#">      </cfif>    </cfif>    <cfif #id_Insumo# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Insumo = #id_Insumo#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Insumo = #id_Insumo#">      </cfif>    </cfif>    <cfif #nu_Cantidad# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nu_Cantidad = #nu_Cantidad#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nu_Cantidad = #nu_Cantidad#">      </cfif>    </cfif>    <cfif #im_PrecioUnitario# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE im_PrecioUnitario = #im_PrecioUnitario#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND im_PrecioUnitario = #im_PrecioUnitario#">      </cfif>    </cfif>    <cfif #nu_CantidadSurtida# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nu_CantidadSurtida = #nu_CantidadSurtida#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nu_CantidadSurtida = #nu_CantidadSurtida#">        </cfif>    </cfif>    <cfif #id_EstatusSurtido# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_EstatusSurtido = #id_EstatusSurtido#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_EstatusSurtido = #id_EstatusSurtido#">      </cfif>    </cfif>    <cfif #id_SucursalCentroCosto# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_SucursalCentroCosto = #id_SucursalCentroCosto#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_SucursalCentroCosto = #id_SucursalCentroCosto#">        </cfif>    </cfif>    <cfif #id_CentroCosto# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_CentroCosto = #id_CentroCosto#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_CentroCosto = #id_CentroCosto#">        </cfif>    </cfif>    <cfif #id_Moneda# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Moneda = #id_Moneda#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Moneda = #id_Moneda#">      </cfif>    </cfif>    <cfif #im_TipoCambio# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE im_TipoCambio = #im_TipoCambio#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND im_TipoCambio = #im_TipoCambio#">      </cfif>    </cfif>    <cfif #id_grupoGasto# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_grupoGasto = #id_grupoGasto#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_grupoGasto = #id_grupoGasto#">      </cfif>    </cfif>    <cfif #id_conceptoGasto# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_conceptoGasto = #id_conceptoGasto#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_conceptoGasto = #id_conceptoGasto#">        </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoRequisicionesDetalle' >        EXECUTE bop_RequisicionesDetalle_ObtenerDinamico '#LOCAL.WhereDinamico#'   </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoRequisicionesDetalle></cffunction><cffunction name='getRSTodos' access='public' returntype='query'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosRequisicionesDetalle' >       EXECUTE bop_RequisicionesDetalle_ObtenerTodos  </cfquery> <cfreturn LOCAL.RS_MostrarTodosRequisicionesDetalle></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_RequisicionDetalle' type='numeric' required='yes'>    <cfargument name='id_Insumo' type='numeric' required='yes'>    <cfargument name='nu_Cantidad' type='numeric' required='yes'>  <cfargument name='im_PrecioUnitario' type='numeric' required='no'> <cfargument name='nu_CantidadSurtida' type='numeric' required='no'>    <cfargument name='id_EstatusSurtido' type='numeric' required='yes'>    <cfargument name='id_SucursalCentroCosto' type='string' required='no'> <cfargument name='id_CentroCosto' type='string' required='no'> <cfargument name='id_Moneda' type='numeric' required='no'> <cfargument name='im_TipoCambio' type='numeric' required='no'> <cfargument name='id_grupoGasto' type='numeric' required='no'> <cfargument name='id_conceptoGasto' type='numeric' required='no'>  <cfargument name='id_GrupoCentroCosto' type='string' required='no'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_RequisicionesDetalle_Agregar #id_Empresa#,         #id_Requisicion#,      #id_RequisicionDetalle#,       #id_Insumo#,       #nu_Cantidad#,         <cfif Not IsDefined('arguments.im_PrecioUnitario')>NULL<cfelse>#im_PrecioUnitario#</cfif>,         <cfif Not IsDefined('arguments.nu_CantidadSurtida')>NULL<cfelse>#nu_CantidadSurtida#</cfif>,       #id_EstatusSurtido#,       <cfif IsDefined('arguments.id_SucursalCentroCosto') AND #arguments.id_SucursalCentroCosto# NEQ ''>#id_SucursalCentroCosto#<cfelse>NULL</cfif>,         <cfif IsDefined('arguments.id_CentroCosto') AND #arguments.id_CentroCosto# NEQ ''>#id_CentroCosto#<cfelse>NULL</cfif>,         <cfif Not IsDefined('arguments.id_Moneda')>NULL<cfelse>#id_Moneda#</cfif>,         <cfif Not IsDefined('arguments.im_TipoCambio')>NULL<cfelse>#im_TipoCambio#</cfif>,         <cfif IsDefined('arguments.id_grupoGasto') AND #arguments.id_grupoGasto# NEQ '0'>#id_grupoGasto#<cfelse>NULL</cfif>,       <cfif IsDefined('arguments.id_conceptoGasto') AND #arguments.id_conceptoGasto# NEQ '0'>#id_conceptoGasto#<cfelse>NULL</cfif>,      <cfif IsDefined('arguments.id_GrupoCentroCosto') AND #arguments.id_GrupoCentroCosto# NEQ ''>#id_GrupoCentroCosto#<cfelse>NULL</cfif>   </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_RequisicionDetalle' type='numeric' required='yes'>    <cfargument name='id_Insumo' type='numeric' required='yes'>    <cfargument name='nu_Cantidad' type='numeric' required='yes'>  <cfargument name='im_PrecioUnitario' type='numeric' required='no'> <cfargument name='nu_CantidadSurtida' type='numeric' required='no'>    <cfargument name='id_EstatusSurtido' type='numeric' required='yes'>    <cfargument name='id_SucursalCentroCosto' type='numeric' required='no'>    <cfargument name='id_CentroCosto' type='numeric' required='no'>    <cfargument name='id_Moneda' type='numeric' required='no'> <cfargument name='im_TipoCambio' type='numeric' required='no'> <cfargument name='id_grupoGasto' type='numeric' required='no'> <cfargument name='id_conceptoGasto' type='numeric' required='no'>  <cfquery datasource="#variables.cnx#" >        EXECUTE bop_RequisicionesDetalle_Actualizar #id_Empresa#, #id_Requisicion#, #id_RequisicionDetalle#, #id_Insumo#, #nu_Cantidad#, <cfif Not IsDefined('arguments.im_PrecioUnitario')>NULL<cfelse>#im_PrecioUnitario#</cfif>, <cfif Not IsDefined('arguments.nu_CantidadSurtida')>NULL<cfelse>#nu_CantidadSurtida#</cfif>, #id_EstatusSurtido#, <cfif Not IsDefined('arguments.id_SucursalCentroCosto')>NULL<cfelse>#id_SucursalCentroCosto#</cfif>, <cfif Not IsDefined('arguments.id_CentroCosto')>NULL<cfelse>#id_CentroCosto#</cfif>, <cfif Not IsDefined('arguments.id_Moneda')>NULL<cfelse>#id_Moneda#</cfif>, <cfif Not IsDefined('arguments.im_TipoCambio')>NULL<cfelse>#im_TipoCambio#</cfif>, <cfif Not IsDefined('arguments.id_grupoGasto')>NULL<cfelse>#id_grupoGasto#</cfif>, <cfif Not IsDefined('arguments.id_conceptoGasto')>NULL<cfelse>#id_conceptoGasto#</cfif>   </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_RequisicionDetalle' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_RequisicionesDetalle_Eliminar #id_Empresa#, #id_Requisicion#, #id_RequisicionDetalle#  </cfquery> <cfreturn></cffunction></cfcomponent>