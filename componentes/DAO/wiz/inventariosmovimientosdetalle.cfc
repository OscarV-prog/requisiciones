<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDInventariosMovimientosDetalle' >        EXECUTE bop_InventariosMovimientosDetalle_ObtenerNextID #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento# </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDInventariosMovimientosDetalle.NextID>  <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfargument name='nd_MovimientoDetalle' type='numeric' required='yes'> <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarInventariosMovimientosDetalle' >       EXECUTE bop_InventariosMovimientosDetalle_ObtenerPorID #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento#, #nd_MovimientoDetalle#  </cfquery> <cfreturn LOCAL.RS_MostrarInventariosMovimientosDetalle></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='no' default='-1'>   <cfargument name='id_Sucursal' type='numeric' required='no' default='-1'>  <cfargument name='id_Almacen' type='numeric' required='no' default='-1'>   <cfargument name='id_Movimiento' type='numeric' required='no' default='-1'>    <cfargument name='nd_MovimientoDetalle' type='numeric' required='no' default='-1'> <cfargument name='id_Insumo' type='numeric' required='no' default='-1'>    <cfargument name='id_CentroCosto' type='numeric' required='no' default='-1'>   <cfargument name='nu_Cantidad' type='numeric' required='no' default=''>    <cfargument name='nu_CantidadRecibidaTraspaso' type='numeric' required='no' default=''>    <cfargument name='nu_CantidadDevolucion' type='numeric' required='no' default=''>  <cfargument name='nu_CantidadFacturada' type='numeric' required='no' default=''>   <cfargument name='im_PrecioUnitarioEntrada' type='numeric' required='no' default='-1'> <cfargument name='im_PrecioTotalEntrada' type='numeric' required='no' default='-1'>    <cfargument name='id_MonedaEntrada' type='numeric' required='no' default='-1'> <cfargument name='im_TipoCambioEntrada' type='numeric' required='no' default='-1'> <cfargument name='im_TotalMN' type='numeric' required='no' default='-1'>   <cfargument name='nu_ExistenciaAnterior' type='numeric' required='no' default=''>  <cfargument name='id_TipoCosteo' type='numeric' required='no' default='-1'>    <cfargument name='id_SucursalProveniente' type='numeric' required='no' default='-1'>   <cfargument name='id_AlmacenProveniente' type='numeric' required='no' default='-1'>    <cfargument name='id_MovimientoProveniente' type='numeric' required='no' default='-1'> <cfargument name='nd_MovimientoDetalleProveniente' type='numeric' required='no' default='-1'>  <cfargument name='id_OrdenDeCompra' type='numeric' required='no' default='-1'> <cfargument name='id_OrdenDeCompraDetalle' type='numeric' required='no' default='-1'>  <cfargument name='id_Requisicion' type='numeric' required='no' default='-1'>   <cfargument name='id_RequisicionDetalle' type='numeric' required='no' default='-1'>    <cfargument name='de_CausaDevolucion' type='string' required='no' default=''>  <cfargument name='id_TipoDevolucion' type='numeric' required='no' default='-1'>    <cfargument name='id_GrupoGasto' type='numeric' required='no' default='-1'>    <cfargument name='id_ConceptoGasto' type='numeric' required='no' default='-1'> <cfargument name='id_Poliza' type='numeric' required='no' default='-1'>    <cfargument name='id_TipoMovimiento' type='numeric' required='no' default='-1'>    <cfset LOCAL.WhereDinamico=''> <cfif #id_Empresa# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Empresa = #id_Empresa#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Empresa = #id_Empresa#">        </cfif>    </cfif>    <cfif #id_Sucursal# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Sucursal = #id_Sucursal#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Sucursal = #id_Sucursal#">      </cfif>    </cfif>    <cfif #id_Almacen# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Almacen = #id_Almacen#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Almacen = #id_Almacen#">        </cfif>    </cfif>    <cfif #id_Movimiento# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Movimiento = #id_Movimiento#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Movimiento = #id_Movimiento#">      </cfif>    </cfif>    <cfif #nd_MovimientoDetalle# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nd_MovimientoDetalle = #nd_MovimientoDetalle#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nd_MovimientoDetalle = #nd_MovimientoDetalle#">        </cfif>    </cfif>    <cfif #id_Insumo# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Insumo = #id_Insumo#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Insumo = #id_Insumo#">      </cfif>    </cfif>    <cfif #id_CentroCosto# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_CentroCosto = #id_CentroCosto#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_CentroCosto = #id_CentroCosto#">        </cfif>    </cfif>    <cfif #nu_Cantidad# NEQ ''>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nu_Cantidad = #nu_Cantidad#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nu_Cantidad = #nu_Cantidad#">      </cfif>    </cfif>    <cfif #nu_CantidadRecibidaTraspaso# NEQ ''>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nu_CantidadRecibidaTraspaso = #nu_CantidadRecibidaTraspaso#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nu_CantidadRecibidaTraspaso = #nu_CantidadRecibidaTraspaso#">      </cfif>    </cfif>    <cfif #nu_CantidadDevolucion# NEQ ''>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nu_CantidadDevolucion = #nu_CantidadDevolucion#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nu_CantidadDevolucion = #nu_CantidadDevolucion#">      </cfif>    </cfif>    <cfif #nu_CantidadFacturada# NEQ ''>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nu_CantidadFacturada = #nu_CantidadFacturada#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nu_CantidadFacturada = #nu_CantidadFacturada#">        </cfif>    </cfif>    <cfif #im_PrecioUnitarioEntrada# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE im_PrecioUnitarioEntrada = #im_PrecioUnitarioEntrada#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND im_PrecioUnitarioEntrada = #im_PrecioUnitarioEntrada#">        </cfif>    </cfif>    <cfif #im_PrecioTotalEntrada# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE im_PrecioTotalEntrada = #im_PrecioTotalEntrada#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND im_PrecioTotalEntrada = #im_PrecioTotalEntrada#">      </cfif>    </cfif>    <cfif #id_MonedaEntrada# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_MonedaEntrada = #id_MonedaEntrada#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_MonedaEntrada = #id_MonedaEntrada#">        </cfif>    </cfif>    <cfif #im_TipoCambioEntrada# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE im_TipoCambioEntrada = #im_TipoCambioEntrada#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND im_TipoCambioEntrada = #im_TipoCambioEntrada#">        </cfif>    </cfif>    <cfif #im_TotalMN# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE im_TotalMN = #im_TotalMN#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND im_TotalMN = #im_TotalMN#">        </cfif>    </cfif>    <cfif #nu_ExistenciaAnterior# NEQ ''>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nu_ExistenciaAnterior = #nu_ExistenciaAnterior#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nu_ExistenciaAnterior = #nu_ExistenciaAnterior#">      </cfif>    </cfif>    <cfif #id_TipoCosteo# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_TipoCosteo = #id_TipoCosteo#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_TipoCosteo = #id_TipoCosteo#">      </cfif>    </cfif>    <cfif #id_SucursalProveniente# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_SucursalProveniente = #id_SucursalProveniente#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_SucursalProveniente = #id_SucursalProveniente#">        </cfif>    </cfif>    <cfif #id_AlmacenProveniente# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_AlmacenProveniente = #id_AlmacenProveniente#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_AlmacenProveniente = #id_AlmacenProveniente#">      </cfif>    </cfif>    <cfif #id_MovimientoProveniente# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_MovimientoProveniente = #id_MovimientoProveniente#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_MovimientoProveniente = #id_MovimientoProveniente#">        </cfif>    </cfif>    <cfif #nd_MovimientoDetalleProveniente# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE nd_MovimientoDetalleProveniente = #nd_MovimientoDetalleProveniente#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND nd_MovimientoDetalleProveniente = #nd_MovimientoDetalleProveniente#">      </cfif>    </cfif>    <cfif #id_OrdenDeCompra# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_OrdenDeCompra = #id_OrdenDeCompra#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_OrdenDeCompra = #id_OrdenDeCompra#">        </cfif>    </cfif>    <cfif #id_OrdenDeCompraDetalle# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_OrdenDeCompraDetalle = #id_OrdenDeCompraDetalle#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_OrdenDeCompraDetalle = #id_OrdenDeCompraDetalle#">      </cfif>    </cfif>    <cfif #id_Requisicion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Requisicion = #id_Requisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Requisicion = #id_Requisicion#">        </cfif>    </cfif>    <cfif #id_RequisicionDetalle# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_RequisicionDetalle = #id_RequisicionDetalle#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_RequisicionDetalle = #id_RequisicionDetalle#">      </cfif>    </cfif>    <cfif #de_CausaDevolucion# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_CausaDevolucion LIKE '#de_CausaDevolucion#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_CausaDevolucion LIKE '#de_CausaDevolucion#%'">      </cfif>    </cfif>    <cfif #id_TipoDevolucion# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_TipoDevolucion = #id_TipoDevolucion#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_TipoDevolucion = #id_TipoDevolucion#">      </cfif>    </cfif>    <cfif #id_GrupoGasto# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_GrupoGasto = #id_GrupoGasto#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_GrupoGasto = #id_GrupoGasto#">      </cfif>    </cfif>    <cfif #id_ConceptoGasto# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_ConceptoGasto = #id_ConceptoGasto#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_ConceptoGasto = #id_ConceptoGasto#">        </cfif>    </cfif>    <cfif #id_Poliza# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Poliza = #id_Poliza#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Poliza = #id_Poliza#">      </cfif>    </cfif>    <cfif #id_TipoMovimiento# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_TipoMovimiento = #id_TipoMovimiento#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_TipoMovimiento = #id_TipoMovimiento#">      </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoInventariosMovimientosDetalle' >       EXECUTE bop_InventariosMovimientosDetalle_ObtenerDinamico '#LOCAL.WhereDinamico#'  </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoInventariosMovimientosDetalle></cffunction><cffunction name='getRSTodos' access='public' returntype='query'>  <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosInventariosMovimientosDetalle' >      EXECUTE bop_InventariosMovimientosDetalle_ObtenerTodos     </cfquery> <cfreturn LOCAL.RS_MostrarTodosInventariosMovimientosDetalle></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfargument name='nd_MovimientoDetalle' type='numeric' required='yes'> <cfargument name='id_Insumo' type='numeric' required='yes'>    <cfargument name='id_CentroCosto' type='numeric' required='no'>    <cfargument name='nu_Cantidad' type='numeric' required='yes'>  <cfargument name='nu_CantidadRecibidaTraspaso' type='numeric' required='no'>   <cfargument name='nu_CantidadDevolucion' type='numeric' required='no'> <cfargument name='nu_CantidadFacturada' type='numeric' required='no'>  <cfargument name='im_PrecioUnitarioEntrada' type='numeric' required='no'>  <cfargument name='im_PrecioTotalEntrada' type='numeric' required='no'> <cfargument name='id_MonedaEntrada' type='numeric' required='no'>  <cfargument name='im_TipoCambioEntrada' type='numeric' required='no'>  <cfargument name='im_TotalMN' type='numeric' required='no'>    <cfargument name='nu_ExistenciaAnterior' type='numeric' required='no'> <cfargument name='id_TipoCosteo' type='numeric' required='no'> <cfargument name='id_SucursalProveniente' type='numeric' required='no'>    <cfargument name='id_AlmacenProveniente' type='numeric' required='no'> <cfargument name='id_MovimientoProveniente' type='numeric' required='no'>  <cfargument name='nd_MovimientoDetalleProveniente' type='numeric' required='no'>   <cfargument name='id_OrdenDeCompra' type='numeric' required='no'>  <cfargument name='id_OrdenDeCompraDetalle' type='numeric' required='no'>   <cfargument name='id_Requisicion' type='numeric' required='no'>    <cfargument name='id_RequisicionDetalle' type='numeric' required='no'> <cfargument name='de_CausaDevolucion' type='string' required='no'> <cfargument name='id_TipoDevolucion' type='numeric' required='no'> <cfargument name='id_GrupoGasto' type='numeric' required='no'> <cfargument name='id_ConceptoGasto' type='numeric' required='no'>  <cfargument name='id_Poliza' type='numeric' required='no'> <cfargument name='id_TipoMovimiento' type='numeric' required='no'> <cfquery datasource="#variables.cnx#" >        EXECUTE bop_InventariosMovimientosDetalle_Agregar #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento#, #nd_MovimientoDetalle#, #id_Insumo#, <cfif Not IsDefined('arguments.id_CentroCosto')>NULL<cfelse>#id_CentroCosto#</cfif>, #nu_Cantidad#, <cfif Not IsDefined('arguments.nu_CantidadRecibidaTraspaso')>NULL<cfelse>#nu_CantidadRecibidaTraspaso#</cfif>, <cfif Not IsDefined('arguments.nu_CantidadDevolucion')>NULL<cfelse>#nu_CantidadDevolucion#</cfif>, <cfif Not IsDefined('arguments.nu_CantidadFacturada')>NULL<cfelse>#nu_CantidadFacturada#</cfif>, <cfif Not IsDefined('arguments.im_PrecioUnitarioEntrada')>NULL<cfelse>#im_PrecioUnitarioEntrada#</cfif>, <cfif Not IsDefined('arguments.im_PrecioTotalEntrada')>NULL<cfelse>#im_PrecioTotalEntrada#</cfif>, <cfif Not IsDefined('arguments.id_MonedaEntrada')>NULL<cfelse>#id_MonedaEntrada#</cfif>, <cfif Not IsDefined('arguments.im_TipoCambioEntrada')>NULL<cfelse>#im_TipoCambioEntrada#</cfif>, <cfif Not IsDefined('arguments.im_TotalMN')>NULL<cfelse>#im_TotalMN#</cfif>, <cfif Not IsDefined('arguments.nu_ExistenciaAnterior')>NULL<cfelse>#nu_ExistenciaAnterior#</cfif>, <cfif Not IsDefined('arguments.id_TipoCosteo')>NULL<cfelse>#id_TipoCosteo#</cfif>, <cfif Not IsDefined('arguments.id_SucursalProveniente')>NULL<cfelse>#id_SucursalProveniente#</cfif>, <cfif Not IsDefined('arguments.id_AlmacenProveniente')>NULL<cfelse>#id_AlmacenProveniente#</cfif>, <cfif Not IsDefined('arguments.id_MovimientoProveniente')>NULL<cfelse>#id_MovimientoProveniente#</cfif>, <cfif Not IsDefined('arguments.nd_MovimientoDetalleProveniente')>NULL<cfelse>#nd_MovimientoDetalleProveniente#</cfif>, <cfif Not IsDefined('arguments.id_OrdenDeCompra')>NULL<cfelse>#id_OrdenDeCompra#</cfif>, <cfif Not IsDefined('arguments.id_OrdenDeCompraDetalle')>NULL<cfelse>#id_OrdenDeCompraDetalle#</cfif>, <cfif Not IsDefined('arguments.id_Requisicion')>NULL<cfelse>#id_Requisicion#</cfif>, <cfif Not IsDefined('arguments.id_RequisicionDetalle')>NULL<cfelse>#id_RequisicionDetalle#</cfif>, <cfif Not IsDefined('arguments.de_CausaDevolucion')>NULL<cfelse>'#de_CausaDevolucion#'</cfif>, <cfif Not IsDefined('arguments.id_TipoDevolucion')>NULL<cfelse>#id_TipoDevolucion#</cfif>, <cfif Not IsDefined('arguments.id_GrupoGasto')>NULL<cfelse>#id_GrupoGasto#</cfif>, <cfif Not IsDefined('arguments.id_ConceptoGasto')>NULL<cfelse>#id_ConceptoGasto#</cfif>, <cfif Not IsDefined('arguments.id_Poliza')>NULL<cfelse>#id_Poliza#</cfif>, <cfif Not IsDefined('arguments.id_TipoMovimiento')>NULL<cfelse>#id_TipoMovimiento#</cfif>  </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfargument name='nd_MovimientoDetalle' type='numeric' required='yes'> <cfargument name='id_Insumo' type='numeric' required='yes'>    <cfargument name='id_CentroCosto' type='numeric' required='no'>    <cfargument name='nu_Cantidad' type='numeric' required='yes'>  <cfargument name='nu_CantidadRecibidaTraspaso' type='numeric' required='no'>   <cfargument name='nu_CantidadDevolucion' type='numeric' required='no'> <cfargument name='nu_CantidadFacturada' type='numeric' required='no'>  <cfargument name='im_PrecioUnitarioEntrada' type='numeric' required='no'>  <cfargument name='im_PrecioTotalEntrada' type='numeric' required='no'> <cfargument name='id_MonedaEntrada' type='numeric' required='no'>  <cfargument name='im_TipoCambioEntrada' type='numeric' required='no'>  <cfargument name='im_TotalMN' type='numeric' required='no'>    <cfargument name='nu_ExistenciaAnterior' type='numeric' required='no'> <cfargument name='id_TipoCosteo' type='numeric' required='no'> <cfargument name='id_SucursalProveniente' type='numeric' required='no'>    <cfargument name='id_AlmacenProveniente' type='numeric' required='no'> <cfargument name='id_MovimientoProveniente' type='numeric' required='no'>  <cfargument name='nd_MovimientoDetalleProveniente' type='numeric' required='no'>   <cfargument name='id_OrdenDeCompra' type='numeric' required='no'>  <cfargument name='id_OrdenDeCompraDetalle' type='numeric' required='no'>   <cfargument name='id_Requisicion' type='numeric' required='no'>    <cfargument name='id_RequisicionDetalle' type='numeric' required='no'> <cfargument name='de_CausaDevolucion' type='string' required='no'> <cfargument name='id_TipoDevolucion' type='numeric' required='no'> <cfargument name='id_GrupoGasto' type='numeric' required='no'> <cfargument name='id_ConceptoGasto' type='numeric' required='no'>  <cfargument name='id_Poliza' type='numeric' required='no'> <cfargument name='id_TipoMovimiento' type='numeric' required='no'> <cfquery datasource="#variables.cnx#" >        EXECUTE bop_InventariosMovimientosDetalle_Actualizar #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento#, #nd_MovimientoDetalle#, #id_Insumo#, <cfif Not IsDefined('arguments.id_CentroCosto')>NULL<cfelse>#id_CentroCosto#</cfif>, #nu_Cantidad#, <cfif Not IsDefined('arguments.nu_CantidadRecibidaTraspaso')>NULL<cfelse>#nu_CantidadRecibidaTraspaso#</cfif>, <cfif Not IsDefined('arguments.nu_CantidadDevolucion')>NULL<cfelse>#nu_CantidadDevolucion#</cfif>, <cfif Not IsDefined('arguments.nu_CantidadFacturada')>NULL<cfelse>#nu_CantidadFacturada#</cfif>, <cfif Not IsDefined('arguments.im_PrecioUnitarioEntrada')>NULL<cfelse>#im_PrecioUnitarioEntrada#</cfif>, <cfif Not IsDefined('arguments.im_PrecioTotalEntrada')>NULL<cfelse>#im_PrecioTotalEntrada#</cfif>, <cfif Not IsDefined('arguments.id_MonedaEntrada')>NULL<cfelse>#id_MonedaEntrada#</cfif>, <cfif Not IsDefined('arguments.im_TipoCambioEntrada')>NULL<cfelse>#im_TipoCambioEntrada#</cfif>, <cfif Not IsDefined('arguments.im_TotalMN')>NULL<cfelse>#im_TotalMN#</cfif>, <cfif Not IsDefined('arguments.nu_ExistenciaAnterior')>NULL<cfelse>#nu_ExistenciaAnterior#</cfif>, <cfif Not IsDefined('arguments.id_TipoCosteo')>NULL<cfelse>#id_TipoCosteo#</cfif>, <cfif Not IsDefined('arguments.id_SucursalProveniente')>NULL<cfelse>#id_SucursalProveniente#</cfif>, <cfif Not IsDefined('arguments.id_AlmacenProveniente')>NULL<cfelse>#id_AlmacenProveniente#</cfif>, <cfif Not IsDefined('arguments.id_MovimientoProveniente')>NULL<cfelse>#id_MovimientoProveniente#</cfif>, <cfif Not IsDefined('arguments.nd_MovimientoDetalleProveniente')>NULL<cfelse>#nd_MovimientoDetalleProveniente#</cfif>, <cfif Not IsDefined('arguments.id_OrdenDeCompra')>NULL<cfelse>#id_OrdenDeCompra#</cfif>, <cfif Not IsDefined('arguments.id_OrdenDeCompraDetalle')>NULL<cfelse>#id_OrdenDeCompraDetalle#</cfif>, <cfif Not IsDefined('arguments.id_Requisicion')>NULL<cfelse>#id_Requisicion#</cfif>, <cfif Not IsDefined('arguments.id_RequisicionDetalle')>NULL<cfelse>#id_RequisicionDetalle#</cfif>, <cfif Not IsDefined('arguments.de_CausaDevolucion')>NULL<cfelse>'#de_CausaDevolucion#'</cfif>, <cfif Not IsDefined('arguments.id_TipoDevolucion')>NULL<cfelse>#id_TipoDevolucion#</cfif>, <cfif Not IsDefined('arguments.id_GrupoGasto')>NULL<cfelse>#id_GrupoGasto#</cfif>, <cfif Not IsDefined('arguments.id_ConceptoGasto')>NULL<cfelse>#id_ConceptoGasto#</cfif>, <cfif Not IsDefined('arguments.id_Poliza')>NULL<cfelse>#id_Poliza#</cfif>, <cfif Not IsDefined('arguments.id_TipoMovimiento')>NULL<cfelse>#id_TipoMovimiento#</cfif>   </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Almacen' type='numeric' required='yes'>   <cfargument name='id_Movimiento' type='numeric' required='yes'>    <cfargument name='nd_MovimientoDetalle' type='numeric' required='yes'> <cfquery datasource="#variables.cnx#" >        EXECUTE bop_InventariosMovimientosDetalle_Eliminar #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento#, #nd_MovimientoDetalle#  </cfquery> <cfreturn></cffunction><cffunction name='getColumnaPorID' access='public' returntype='string'>  <cfargument name='id_Empresa' type='string' required='yes'>    <cfargument name='id_Sucursal' type='string' required='yes'>   <cfargument name='id_Almacen' type='string' required='yes'>    <cfargument name='id_Movimiento' type='string' required='yes'> <cfargument name='nd_MovimientoDetalle' type='string' required='yes'>  <cfargument name='nb_Campo' type='string' required='yes'>  <cfif  Not IsNumeric(id_Empresa) OR Not IsNumeric(id_Sucursal) OR Not IsNumeric(id_Almacen) OR Not IsNumeric(id_Movimiento) OR Not IsNumeric(nd_MovimientoDetalle)>        <cfset LOCAL.Columna_Retorno= ''>  <cfelse>       <cfquery datasource="#variables.cnx#" name='LOCAL.RS_Mostrar_InventariosMovimientosDetalle' >          EXECUTE bop_InventariosMovimientosDetalle_ObtenerPorID #id_Empresa#, #id_Sucursal#, #id_Almacen#, #id_Movimiento#, #nd_MovimientoDetalle#      </cfquery>     <cfset LOCAL.Columna_Retorno= Evaluate('LOCAL.RS_Mostrar_InventariosMovimientosDetalle.#nb_Campo#')>   </cfif>    <cfreturn LOCAL.Columna_Retorno></cffunction></cfcomponent>