<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDEstatusSurtidoRequisiciones' >      EXECUTE bop_EstatusSurtidoRequisiciones_ObtenerNextID  </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDEstatusSurtidoRequisiciones.NextID>    <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_EstatusSurtidoRequisicion' type='numeric' required='yes'> <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarEstatusSurtidoRequisiciones' >     EXECUTE bop_EstatusSurtidoRequisiciones_ObtenerPorID #id_EstatusSurtidoRequisicion#    </cfquery> <cfreturn LOCAL.RS_MostrarEstatusSurtidoRequisiciones></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'> <cfargument name='id_EstatusSurtidoRequisicion' type='numeric' required='no' default='-1'> <cfargument name='de_EstatusSurtidoRequisicion' type='string' required='no' default=''>    <cfargument name='sn_Activo' type='boolean' required='no' default='-1'>    <cfset LOCAL.WhereDinamico=''> <cfif #id_EstatusSurtidoRequisicion# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_EstatusSurtidoRequisicion = #id_EstatusSurtidoRequisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_EstatusSurtidoRequisicion = #id_EstatusSurtidoRequisicion#">        </cfif>    </cfif>    <cfif #de_EstatusSurtidoRequisicion# NEQ ''>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_EstatusSurtidoRequisicion LIKE '#de_EstatusSurtidoRequisicion#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_EstatusSurtidoRequisicion LIKE '#de_EstatusSurtidoRequisicion#%'">      </cfif>    </cfif>    <cfif #sn_Activo# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE sn_Activo = #sn_Activo#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND sn_Activo = #sn_Activo#">      </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoEstatusSurtidoRequisiciones' >     EXECUTE bop_EstatusSurtidoRequisiciones_ObtenerDinamico '#LOCAL.WhereDinamico#'    </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoEstatusSurtidoRequisiciones></cffunction><cffunction name='getRSTodos' access='public' returntype='query'>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosEstatusSurtidoRequisiciones' >        EXECUTE bop_EstatusSurtidoRequisiciones_ObtenerTodos   </cfquery> <cfreturn LOCAL.RS_MostrarTodosEstatusSurtidoRequisiciones></cffunction><cffunction name='RSAgregar' access='public' returntype='void'> <cfargument name='id_EstatusSurtidoRequisicion' type='numeric' required='yes'> <cfargument name='de_EstatusSurtidoRequisicion' type='string' required='yes'>  <cfargument name='sn_Activo' type='boolean' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_EstatusSurtidoRequisiciones_Agregar #id_EstatusSurtidoRequisicion#, '#de_EstatusSurtidoRequisicion#', #sn_Activo#  </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_EstatusSurtidoRequisicion' type='numeric' required='yes'> <cfargument name='de_EstatusSurtidoRequisicion' type='string' required='yes'>  <cfargument name='sn_Activo' type='boolean' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_EstatusSurtidoRequisiciones_Actualizar #id_EstatusSurtidoRequisicion#, '#de_EstatusSurtidoRequisicion#', #sn_Activo#   </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_EstatusSurtidoRequisicion' type='numeric' required='yes'> <cfquery datasource="#variables.cnx#" >        EXECUTE bop_EstatusSurtidoRequisiciones_Eliminar #id_EstatusSurtidoRequisicion#    </cfquery> <cfreturn></cffunction></cfcomponent>