<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDTiposRequisiciones' >       EXECUTE bop_TiposRequisiciones_ObtenerNextID   </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDTiposRequisiciones.NextID> <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_TipoRequisicion' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTiposRequisiciones' >      EXECUTE bop_TiposRequisiciones_ObtenerPorID #id_TipoRequisicion#   </cfquery> <cfreturn LOCAL.RS_MostrarTiposRequisiciones></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>  <cfargument name='id_TipoRequisicion' type='numeric' required='no' default='-1'>   <cfargument name='de_TipoRequisicion' type='string' required='no' default=''>  <cfargument name='sn_Activo' type='boolean' required='no' default='-1'>    <cfset LOCAL.WhereDinamico=''> <cfif #id_TipoRequisicion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_TipoRequisicion = #id_TipoRequisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_TipoRequisicion = #id_TipoRequisicion#">        </cfif>    </cfif>    <cfif #de_TipoRequisicion# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_TipoRequisicion LIKE '#de_TipoRequisicion#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_TipoRequisicion LIKE '#de_TipoRequisicion#%'">      </cfif>    </cfif>    <cfif #sn_Activo# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE sn_Activo = #sn_Activo#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND sn_Activo = #sn_Activo#">      </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoTiposRequisiciones' >      EXECUTE bop_TiposRequisiciones_ObtenerDinamico '#LOCAL.WhereDinamico#' </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoTiposRequisiciones></cffunction><cffunction name='getRSTodos' access='public' returntype='query'> <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosTiposRequisiciones' >     EXECUTE bop_TiposRequisiciones_ObtenerTodos    </cfquery> <cfreturn LOCAL.RS_MostrarTodosTiposRequisiciones></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>  <cfargument name='id_TipoRequisicion' type='numeric' required='yes'>   <cfargument name='de_TipoRequisicion' type='string' required='yes'>    <cfargument name='sn_Activo' type='boolean' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_TiposRequisiciones_Agregar #id_TipoRequisicion#, '#de_TipoRequisicion#', #sn_Activo#   </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_TipoRequisicion' type='numeric' required='yes'>   <cfargument name='de_TipoRequisicion' type='string' required='yes'>    <cfargument name='sn_Activo' type='boolean' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_TiposRequisiciones_Actualizar #id_TipoRequisicion#, '#de_TipoRequisicion#', #sn_Activo#    </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_TipoRequisicion' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" >        EXECUTE bop_TiposRequisiciones_Eliminar #id_TipoRequisicion#   </cfquery> <cfreturn></cffunction></cfcomponent>