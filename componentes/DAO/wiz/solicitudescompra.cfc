<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDSolicitudesCompra' >        EXECUTE bop_SolicitudesCompra_ObtenerNextID #id_Empresa#   </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDSolicitudesCompra.NextID>  <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_SolicitudCompra' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarSolicitudesCompra' >       EXECUTE bop_SolicitudesCompra_ObtenerPorID #id_Empresa#, #id_SolicitudCompra#  </cfquery> <cfreturn LOCAL.RS_MostrarSolicitudesCompra></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='no' default='-1'>   <cfargument name='id_SolicitudCompra' type='numeric' required='no' default='-1'>   <cfargument name='id_UsuarioRegistro' type='numeric' required='no' default='-1'>   <cfargument name='fh_Registro' type='date' required='no' default=''>   <cfargument name='id_Requisicion' type='numeric' required='no' default='-1'>   <cfset LOCAL.WhereDinamico=''> <cfif #id_Empresa# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Empresa = #id_Empresa#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Empresa = #id_Empresa#">        </cfif>    </cfif>    <cfif #id_SolicitudCompra# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_SolicitudCompra = #id_SolicitudCompra#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_SolicitudCompra = #id_SolicitudCompra#">        </cfif>    </cfif>    <cfif #id_UsuarioRegistro# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_UsuarioRegistro = #id_UsuarioRegistro#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_UsuarioRegistro = #id_UsuarioRegistro#">        </cfif>    </cfif>    <cfif #fh_Registro# NEQ ''>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fh_Registro = '#fh_Registro#'">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fh_Registro = '#fh_Registro#'">        </cfif>    </cfif>    <cfif #id_Requisicion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Requisicion = #id_Requisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Requisicion = #id_Requisicion#">        </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoSolicitudesCompra' >       EXECUTE bop_SolicitudesCompra_ObtenerDinamico '#LOCAL.WhereDinamico#'  </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoSolicitudesCompra></cffunction><cffunction name='getRSTodos' access='public' returntype='query'>  <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosSolicitudesCompra' >      EXECUTE bop_SolicitudesCompra_ObtenerTodos     </cfquery> <cfreturn LOCAL.RS_MostrarTodosSolicitudesCompra></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_SolicitudCompra' type='numeric' required='yes'>   <cfargument name='id_UsuarioRegistro' type='numeric' required='yes'>   <cfargument name='fh_Registro' type='date' required='yes'> <cfargument name='id_Requisicion' type='numeric' required='no'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_SolicitudesCompra_Agregar #id_Empresa#, #id_SolicitudCompra#, #id_UsuarioRegistro#, '#fh_Registro#', <cfif Not IsDefined('arguments.id_Requisicion')>NULL<cfelse>#id_Requisicion#</cfif>   </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_SolicitudCompra' type='numeric' required='yes'>   <cfargument name='id_UsuarioRegistro' type='numeric' required='yes'>   <cfargument name='fh_Registro' type='date' required='yes'> <cfargument name='id_Requisicion' type='numeric' required='no'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_SolicitudesCompra_Actualizar #id_Empresa#, #id_SolicitudCompra#, #id_UsuarioRegistro#, '#fh_Registro#', <cfif Not IsDefined('arguments.id_Requisicion')>NULL<cfelse>#id_Requisicion#</cfif>    </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_SolicitudCompra' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" >        EXECUTE bop_SolicitudesCompra_Eliminar #id_Empresa#, #id_SolicitudCompra#  </cfquery> <cfreturn></cffunction></cfcomponent>