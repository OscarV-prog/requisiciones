<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDRequisicionesUsuariosAutorizan' >       EXECUTE bop_RequisicionesUsuariosAutorizan_ObtenerNextID #id_Empresa#, #id_Requisicion#    </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDRequisicionesUsuariosAutorizan.NextID> <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_RequisicionUsuarioAutoriza' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarRequisicionesUsuariosAutorizan' >      EXECUTE bop_RequisicionesUsuariosAutorizan_ObtenerPorID #id_Empresa#, #id_Requisicion#, #id_RequisicionUsuarioAutoriza#    </cfquery> <cfreturn LOCAL.RS_MostrarRequisicionesUsuariosAutorizan></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>  <cfargument name='id_Empresa' type='numeric' required='no' default='-1'>   <cfargument name='id_Requisicion' type='numeric' required='no' default='-1'>   <cfargument name='id_RequisicionUsuarioAutoriza' type='numeric' required='no' default='-1'>    <cfargument name='id_UsuarioAutoriza' type='numeric' required='no' default='-1'>   <cfargument name='id_EstatusAutorizacionRequisicion' type='numeric' required='no' default='-1'>    <cfargument name='fh_AsignacionEstatus' type='date' required='no' default=''>  <cfargument name='de_Comentarios' type='string' required='no' default=''>  <cfset LOCAL.WhereDinamico=''> <cfif #id_Empresa# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Empresa = #id_Empresa#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Empresa = #id_Empresa#">        </cfif>    </cfif>    <cfif #id_Requisicion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Requisicion = #id_Requisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Requisicion = #id_Requisicion#">        </cfif>    </cfif>    <cfif #id_RequisicionUsuarioAutoriza# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_RequisicionUsuarioAutoriza = #id_RequisicionUsuarioAutoriza#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_RequisicionUsuarioAutoriza = #id_RequisicionUsuarioAutoriza#">      </cfif>    </cfif>    <cfif #id_UsuarioAutoriza# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_UsuarioAutoriza = #id_UsuarioAutoriza#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_UsuarioAutoriza = #id_UsuarioAutoriza#">        </cfif>    </cfif>    <cfif #id_EstatusAutorizacionRequisicion# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_EstatusAutorizacionRequisicion = #id_EstatusAutorizacionRequisicion#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_EstatusAutorizacionRequisicion = #id_EstatusAutorizacionRequisicion#">      </cfif>    </cfif>    <cfif #fh_AsignacionEstatus# NEQ ''>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fh_AsignacionEstatus = '#fh_AsignacionEstatus#'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fh_AsignacionEstatus = '#fh_AsignacionEstatus#'">      </cfif>    </cfif>    <cfif #de_Comentarios# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_Comentarios LIKE '#de_Comentarios#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_Comentarios LIKE '#de_Comentarios#%'">      </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoRequisicionesUsuariosAutorizan' >      EXECUTE bop_RequisicionesUsuariosAutorizan_ObtenerDinamico '#LOCAL.WhereDinamico#' </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoRequisicionesUsuariosAutorizan></cffunction><cffunction name='getRSTodos' access='public' returntype='query'> <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosRequisicionesUsuariosAutorizan' >     EXECUTE bop_RequisicionesUsuariosAutorizan_ObtenerTodos    </cfquery> <cfreturn LOCAL.RS_MostrarTodosRequisicionesUsuariosAutorizan></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>  <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_RequisicionUsuarioAutoriza' type='numeric' required='yes'>    <cfargument name='id_UsuarioAutoriza' type='numeric' required='yes'>   <cfargument name='id_EstatusAutorizacionRequisicion' type='numeric' required='no'> <cfargument name='fh_AsignacionEstatus' type='date' required='no'> <cfargument name='de_Comentarios' type='string' required='no'> <cfquery datasource="#variables.cnx#" >        EXECUTE bop_RequisicionesUsuariosAutorizan_Agregar #id_Empresa#, #id_Requisicion#, #id_RequisicionUsuarioAutoriza#, #id_UsuarioAutoriza#, <cfif Not IsDefined('arguments.id_EstatusAutorizacionRequisicion')>NULL<cfelse>#id_EstatusAutorizacionRequisicion#</cfif>,           <cfif Not IsDefined('arguments.fh_AsignacionEstatus')>NULL<cfelse>'#fh_AsignacionEstatus#'</cfif>,             <cfif Not IsDefined('arguments.de_Comentarios')>NULL<cfelse>'#de_Comentarios#'</cfif>  </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_RequisicionUsuarioAutoriza' type='numeric' required='yes'>    <cfargument name='id_UsuarioAutoriza' type='numeric' required='yes'>   <cfargument name='id_EstatusAutorizacionRequisicion' type='numeric' required='no'> <cfargument name='fh_AsignacionEstatus' type='date' required='no'> <cfargument name='de_Comentarios' type='string' required='no'> <cfquery datasource="#variables.cnx#" >        EXECUTE bop_RequisicionesUsuariosAutorizan_Actualizar #id_Empresa#, #id_Requisicion#, #id_RequisicionUsuarioAutoriza#, #id_UsuarioAutoriza#, <cfif Not IsDefined('arguments.id_EstatusAutorizacionRequisicion')>NULL<cfelse>#id_EstatusAutorizacionRequisicion#</cfif>, <cfif Not IsDefined('arguments.fh_AsignacionEstatus')>NULL<cfelse>'#fh_AsignacionEstatus#'</cfif>, <cfif Not IsDefined('arguments.de_Comentarios')>NULL<cfelse>'#de_Comentarios#'</cfif>   </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_RequisicionUsuarioAutoriza' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_RequisicionesUsuariosAutorizan_Eliminar #id_Empresa#, #id_Requisicion#, #id_RequisicionUsuarioAutoriza#    </cfquery> <cfreturn></cffunction></cfcomponent>