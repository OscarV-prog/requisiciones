<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDRequisiciones' >        EXECUTE bop_Requisiciones_ObtenerNextID #id_Empresa#   </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDRequisiciones.NextID>  <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarRequisiciones' >       EXECUTE bop_Requisiciones_ObtenerPorID #id_Empresa#, #id_Requisicion#  </cfquery> <cfreturn LOCAL.RS_MostrarRequisiciones></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='no' default='-1'>   <cfargument name='id_Requisicion' type='numeric' required='no' default='-1'>   <cfargument name='id_TipoRequisicion' type='numeric' required='no' default='-1'>   <cfargument name='id_UsuarioSolicita' type='numeric' required='no' default='-1'>   <cfargument name='id_Departamento' type='numeric' required='no' default='-1'>  <cfargument name='id_SucursalSolicita' type='numeric' required='no' default='-1'>  <cfargument name='id_ClasificadoRequisicion' type='numeric' required='no' default='-1'>    <cfargument name='fh_Expedicion' type='date' required='no' default=''> <cfargument name='im_PrecioTotal' type='date' required='no' default=''>    <cfargument name='id_Proveedor' type='numeric' required='no' default='-1'> <cfargument name='de_Observaciones' type='string' required='no' default=''>    <cfargument name='id_EstatusAutorizacion' type='numeric' required='no' default='-1'>   <cfargument name='id_EstatusSurtido' type='numeric' required='no' default='-1'>    <cfargument name='fh_RegistroRequisicion' type='date' required='no' default=''>    <cfset LOCAL.WhereDinamico=''> <cfif #id_Empresa# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Empresa = #id_Empresa#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Empresa = #id_Empresa#">        </cfif>    </cfif>    <cfif #id_Requisicion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Requisicion = #id_Requisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Requisicion = #id_Requisicion#">        </cfif>    </cfif>    <cfif #id_TipoRequisicion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_TipoRequisicion = #id_TipoRequisicion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_TipoRequisicion = #id_TipoRequisicion#">        </cfif>    </cfif>    <cfif #id_UsuarioSolicita# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_UsuarioSolicita = #id_UsuarioSolicita#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_UsuarioSolicita = #id_UsuarioSolicita#">        </cfif>    </cfif>    <cfif #id_Departamento# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Departamento = #id_Departamento#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Departamento = #id_Departamento#">      </cfif>    </cfif>    <cfif #id_SucursalSolicita# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_SucursalSolicita = #id_SucursalSolicita#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_SucursalSolicita = #id_SucursalSolicita#">      </cfif>    </cfif>    <cfif #id_ClasificadoRequisicion# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_ClasificadoRequisicion = #id_ClasificadoRequisicion#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_ClasificadoRequisicion = #id_ClasificadoRequisicion#">      </cfif>    </cfif>    <cfif #fh_Expedicion# NEQ ''>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fh_Expedicion = '#fh_Expedicion#'">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fh_Expedicion = '#fh_Expedicion#'">        </cfif>    </cfif>    <cfif #im_PrecioTotal# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE im_PrecioTotal = '#im_PrecioTotal#'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND im_PrecioTotal = '#im_PrecioTotal#'">      </cfif>    </cfif>    <cfif #id_Proveedor# NEQ '-1'>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Proveedor = #id_Proveedor#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Proveedor = #id_Proveedor#">        </cfif>    </cfif>    <cfif #de_Observaciones# NEQ ''>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_Observaciones LIKE '#de_Observaciones#%'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_Observaciones LIKE '#de_Observaciones#%'">      </cfif>    </cfif>    <cfif #id_EstatusAutorizacion# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_EstatusAutorizacion = #id_EstatusAutorizacion#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_EstatusAutorizacion = #id_EstatusAutorizacion#">        </cfif>    </cfif>    <cfif #id_EstatusSurtido# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_EstatusSurtido = #id_EstatusSurtido#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_EstatusSurtido = #id_EstatusSurtido#">      </cfif>    </cfif>    <cfif #fh_RegistroRequisicion# NEQ ''>     <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE fh_RegistroRequisicion = '#fh_RegistroRequisicion#'">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND fh_RegistroRequisicion = '#fh_RegistroRequisicion#'">      </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoRequisiciones' >       EXECUTE bop_Requisiciones_ObtenerDinamico '#LOCAL.WhereDinamico#'  </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoRequisiciones></cffunction><cffunction name='getRSTodos' access='public' returntype='query'>  <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosRequisiciones' >      EXECUTE bop_Requisiciones_ObtenerTodos     </cfquery> <cfreturn LOCAL.RS_MostrarTodosRequisiciones></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_TipoRequisicion' type='numeric' required='yes'>   <cfargument name='id_UsuarioSolicita' type='numeric' required='yes'>   <cfargument name='id_Departamento' type='numeric' required='yes'>  <cfargument name='id_SucursalSolicita' type='numeric' required='yes'>  <cfargument name='id_ClasificadoRequisicion' type='numeric' required='yes'>    <cfargument name='fh_Expedicion' type='date' required='no'>    <cfargument name='im_PrecioTotal' type='date' required='no'>   <cfargument name='id_Proveedor' type='numeric' required='no'>  <cfargument name='de_Observaciones' type='string' required='no'>   <cfargument name='id_EstatusAutorizacion' type='numeric' required='yes'>   <cfargument name='id_EstatusSurtido' type='numeric' required='yes'>    <cfargument name='fh_RegistroRequisicion' type='date' required='yes'>  <cfquery datasource="#variables.cnx#" >        EXECUTE bop_Requisiciones_Agregar #id_Empresa#, #id_Requisicion#, #id_TipoRequisicion#, #id_UsuarioSolicita#, #id_Departamento#, #id_SucursalSolicita#, #id_ClasificadoRequisicion#, <cfif Not IsDefined('arguments.fh_Expedicion')>NULL<cfelse>'#fh_Expedicion#'</cfif>, <cfif Not IsDefined('arguments.im_PrecioTotal')>NULL<cfelse>'#im_PrecioTotal#'</cfif>, <cfif Not IsDefined('arguments.id_Proveedor')>NULL<cfelse>#id_Proveedor#</cfif>, <cfif Not IsDefined('arguments.de_Observaciones')>NULL<cfelse>'#de_Observaciones#'</cfif>, #id_EstatusAutorizacion#, #id_EstatusSurtido#, '#fh_RegistroRequisicion#' </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>   <cfargument name='id_TipoRequisicion' type='numeric' required='yes'>   <cfargument name='id_UsuarioSolicita' type='numeric' required='yes'>   <cfargument name='id_Departamento' type='numeric' required='yes'>  <cfargument name='id_SucursalSolicita' type='numeric' required='yes'>  <cfargument name='id_ClasificadoRequisicion' type='numeric' required='yes'>    <cfargument name='fh_Expedicion' type='date' required='no'>    <cfargument name='im_PrecioTotal' type='date' required='no'>   <cfargument name='id_Proveedor' type='numeric' required='no'>  <cfargument name='de_Observaciones' type='string' required='no'>   <cfargument name='id_EstatusAutorizacion' type='numeric' required='yes'>   <cfargument name='id_EstatusSurtido' type='numeric' required='yes'>    <cfargument name='fh_RegistroRequisicion' type='date' required='yes'>  <cfquery datasource="#variables.cnx#" >        EXECUTE bop_Requisiciones_Actualizar #id_Empresa#, #id_Requisicion#, #id_TipoRequisicion#, #id_UsuarioSolicita#, #id_Departamento#, #id_SucursalSolicita#, #id_ClasificadoRequisicion#, <cfif Not IsDefined('arguments.fh_Expedicion')>NULL<cfelse>'#fh_Expedicion#'</cfif>, <cfif Not IsDefined('arguments.im_PrecioTotal')>NULL<cfelse>'#im_PrecioTotal#'</cfif>, <cfif Not IsDefined('arguments.id_Proveedor')>NULL<cfelse>#id_Proveedor#</cfif>, <cfif Not IsDefined('arguments.de_Observaciones')>NULL<cfelse>'#de_Observaciones#'</cfif>, #id_EstatusAutorizacion#, #id_EstatusSurtido#, '#fh_RegistroRequisicion#'  </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Requisicion' type='numeric' required='yes'>      <cfquery datasource="#variables.cnx#" >        EXECUTE bop_Requisiciones_Eliminar #id_Empresa#, #id_Requisicion#  </cfquery> <cfreturn></cffunction></cfcomponent>