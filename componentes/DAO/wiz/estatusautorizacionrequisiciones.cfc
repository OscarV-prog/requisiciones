<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDEstatusAutorizacionRequisiciones' >     EXECUTE bop_EstatusAutorizacionRequisiciones_ObtenerNextID     </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDEstatusAutorizacionRequisiciones.NextID>   <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_EstatusAutorizacionRequisicion' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarEstatusAutorizacionRequisiciones' >        EXECUTE bop_EstatusAutorizacionRequisiciones_ObtenerPorID #id_EstatusAutorizacionRequisicion#  </cfquery> <cfreturn LOCAL.RS_MostrarEstatusAutorizacionRequisiciones></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>    <cfargument name='id_EstatusAutorizacionRequisicion' type='numeric' required='no' default='-1'>    <cfargument name='de_EstatusAutorizacionRequisicion' type='string' required='no' default=''>   <cfargument name='sn_Activo' type='boolean' required='no' default='-1'>    <cfset LOCAL.WhereDinamico=''> <cfif #id_EstatusAutorizacionRequisicion# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_EstatusAutorizacionRequisicion = #id_EstatusAutorizacionRequisicion#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_EstatusAutorizacionRequisicion = #id_EstatusAutorizacionRequisicion#">      </cfif>    </cfif>    <cfif #de_EstatusAutorizacionRequisicion# NEQ ''>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE de_EstatusAutorizacionRequisicion LIKE '#de_EstatusAutorizacionRequisicion#%'">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND de_EstatusAutorizacionRequisicion LIKE '#de_EstatusAutorizacionRequisicion#%'">        </cfif>    </cfif>    <cfif #sn_Activo# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE sn_Activo = #sn_Activo#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND sn_Activo = #sn_Activo#">      </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoEstatusAutorizacionRequisiciones' >        EXECUTE bop_EstatusAutorizacionRequisiciones_ObtenerDinamico '#LOCAL.WhereDinamico#'   </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoEstatusAutorizacionRequisiciones></cffunction><cffunction name='getRSTodos' access='public' returntype='query'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosEstatusAutorizacionRequisiciones' >       EXECUTE bop_EstatusAutorizacionRequisiciones_ObtenerTodos  </cfquery> <cfreturn LOCAL.RS_MostrarTodosEstatusAutorizacionRequisiciones></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>    <cfargument name='id_EstatusAutorizacionRequisicion' type='numeric' required='yes'>    <cfargument name='de_EstatusAutorizacionRequisicion' type='string' required='yes'> <cfargument name='sn_Activo' type='boolean' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_EstatusAutorizacionRequisiciones_Agregar #id_EstatusAutorizacionRequisicion#, '#de_EstatusAutorizacionRequisicion#', #sn_Activo#   </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_EstatusAutorizacionRequisicion' type='numeric' required='yes'>    <cfargument name='de_EstatusAutorizacionRequisicion' type='string' required='yes'> <cfargument name='sn_Activo' type='boolean' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_EstatusAutorizacionRequisiciones_Actualizar #id_EstatusAutorizacionRequisicion#, '#de_EstatusAutorizacionRequisicion#', #sn_Activo#    </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_EstatusAutorizacionRequisicion' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" >        EXECUTE bop_EstatusAutorizacionRequisiciones_Eliminar #id_EstatusAutorizacionRequisicion#  </cfquery> <cfreturn></cffunction></cfcomponent>