<cfcomponent extends='conexion' output='no'><cffunction name='getNextID' access='public' returntype='numeric'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Departamento' type='numeric' required='yes'>  <cfargument name='id_Puesto' type='numeric' required='yes'>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_NextIDConfiguracionNotificacionesRegistroRequisiciones' >     EXECUTE bop_ConfiguracionNotificacionesRegistroRequisiciones_ObtenerNextID #id_Empresa#, #id_Sucursal#, #id_Departamento#, #id_Puesto# </cfquery> <cfset LOCAL.NextID= LOCAL.RS_NextIDConfiguracionNotificacionesRegistroRequisiciones.NextID>   <cfreturn LOCAL.NextID></cffunction><cffunction name='getRSPorID' access='public' returntype='query'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Departamento' type='numeric' required='yes'>  <cfargument name='id_Puesto' type='numeric' required='yes'>    <cfargument name='id_ConfiguracionNotificacionRegistroRequisicion' type='numeric' required='yes'>  <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarConfiguracionNotificacionesRegistroRequisiciones' >        EXECUTE bop_ConfiguracionNotificacionesRegistroRequisiciones_ObtenerPorID #id_Empresa#, #id_Sucursal#, #id_Departamento#, #id_Puesto#, #id_ConfiguracionNotificacionRegistroRequisicion#   </cfquery> <cfreturn LOCAL.RS_MostrarConfiguracionNotificacionesRegistroRequisiciones></cffunction><cffunction name='getRSDinamico' access='public' returntype='query'>    <cfargument name='id_Empresa' type='numeric' required='no' default='-1'>   <cfargument name='id_Sucursal' type='numeric' required='no' default='-1'>  <cfargument name='id_Departamento' type='numeric' required='no' default='-1'>  <cfargument name='id_Puesto' type='numeric' required='no' default='-1'>    <cfargument name='id_ConfiguracionNotificacionRegistroRequisicion' type='numeric' required='no' default='-1'>  <cfargument name='id_EmpresaEmpleado' type='numeric' required='no' default='-1'>   <cfargument name='id_Empleado' type='numeric' required='no' default='-1'>  <cfset LOCAL.WhereDinamico=''> <cfif #id_Empresa# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Empresa = #id_Empresa#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Empresa = #id_Empresa#">        </cfif>    </cfif>    <cfif #id_Sucursal# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Sucursal = #id_Sucursal#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Sucursal = #id_Sucursal#">      </cfif>    </cfif>    <cfif #id_Departamento# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Departamento = #id_Departamento#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Departamento = #id_Departamento#">      </cfif>    </cfif>    <cfif #id_Puesto# NEQ '-1'>        <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Puesto = #id_Puesto#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Puesto = #id_Puesto#">      </cfif>    </cfif>    <cfif #id_ConfiguracionNotificacionRegistroRequisicion# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_ConfiguracionNotificacionRegistroRequisicion = #id_ConfiguracionNotificacionRegistroRequisicion#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_ConfiguracionNotificacionRegistroRequisicion = #id_ConfiguracionNotificacionRegistroRequisicion#">      </cfif>    </cfif>    <cfif #id_EmpresaEmpleado# NEQ '-1'>       <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_EmpresaEmpleado = #id_EmpresaEmpleado#">     <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_EmpresaEmpleado = #id_EmpresaEmpleado#">        </cfif>    </cfif>    <cfif #id_Empleado# NEQ '-1'>      <cfif LOCAL.WhereDinamico EQ ''>           <cfset LOCAL.WhereDinamico= "WHERE id_Empleado = #id_Empleado#">       <cfelse>           <cfset LOCAL.WhereDinamico= LOCAL.WhereDinamico & " AND id_Empleado = #id_Empleado#">      </cfif>    </cfif>    <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarDinamicoConfiguracionNotificacionesRegistroRequisiciones' >        EXECUTE bop_ConfiguracionNotificacionesRegistroRequisiciones_ObtenerDinamico '#LOCAL.WhereDinamico#'   </cfquery> <cfreturn LOCAL.RS_MostrarDinamicoConfiguracionNotificacionesRegistroRequisiciones></cffunction><cffunction name='getRSTodos' access='public' returntype='query'>   <cfquery datasource="#variables.cnx#" name='LOCAL.RS_MostrarTodosConfiguracionNotificacionesRegistroRequisiciones' >       EXECUTE bop_ConfiguracionNotificacionesRegistroRequisiciones_ObtenerTodos  </cfquery> <cfreturn LOCAL.RS_MostrarTodosConfiguracionNotificacionesRegistroRequisiciones></cffunction><cffunction name='RSAgregar' access='public' returntype='void'>    <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Departamento' type='numeric' required='yes'>  <cfargument name='id_Puesto' type='numeric' required='yes'>    <cfargument name='id_ConfiguracionNotificacionRegistroRequisicion' type='numeric' required='yes'>  <cfargument name='id_EmpresaEmpleado' type='numeric' required='yes'>   <cfargument name='id_Empleado' type='numeric' required='yes'>  <cfquery datasource="#variables.cnx#" >        EXECUTE bop_ConfiguracionNotificacionesRegistroRequisiciones_Agregar #id_Empresa#, #id_Sucursal#, #id_Departamento#, #id_Puesto#, #id_ConfiguracionNotificacionRegistroRequisicion#, #id_EmpresaEmpleado#, #id_Empleado#   </cfquery> <cfreturn></cffunction><cffunction name='RSEditar' access='public' returntype='void'>   <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Departamento' type='numeric' required='yes'>  <cfargument name='id_Puesto' type='numeric' required='yes'>    <cfargument name='id_ConfiguracionNotificacionRegistroRequisicion' type='numeric' required='yes'>  <cfargument name='id_EmpresaEmpleado' type='numeric' required='yes'>   <cfargument name='id_Empleado' type='numeric' required='yes'>  <cfquery datasource="#variables.cnx#" >        EXECUTE bop_ConfiguracionNotificacionesRegistroRequisiciones_Actualizar #id_Empresa#, #id_Sucursal#, #id_Departamento#, #id_Puesto#, #id_ConfiguracionNotificacionRegistroRequisicion#, #id_EmpresaEmpleado#, #id_Empleado#    </cfquery> <cfreturn></cffunction><cffunction name='RSEliminar' access='public' returntype='void'> <cfargument name='id_Empresa' type='numeric' required='yes'>   <cfargument name='id_Sucursal' type='numeric' required='yes'>  <cfargument name='id_Departamento' type='numeric' required='yes'>  <cfargument name='id_Puesto' type='numeric' required='yes'>    <cfargument name='id_ConfiguracionNotificacionRegistroRequisicion' type='numeric' required='yes'>  <cfquery datasource="#variables.cnx#" >        EXECUTE bop_ConfiguracionNotificacionesRegistroRequisiciones_Eliminar #id_Empresa#, #id_Sucursal#, #id_Departamento#, #id_Puesto#, #id_ConfiguracionNotificacionRegistroRequisicion#   </cfquery> <cfreturn></cffunction></cfcomponent>